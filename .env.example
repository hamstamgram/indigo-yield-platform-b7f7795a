# ============================================================================
# Indigo Yield Platform - Environment Variables Template
# ============================================================================
#
# IMPORTANT:
# 1. Copy this file to .env.local for local development
# 2. Copy this file to .env.development for dev environment
# 3. Copy this file to .env.staging for staging environment
# 4. Copy this file to .env.production for production environment
# 5. NEVER commit actual credentials to git
#
# For deployment platforms (Lovable, Netlify, etc):
# - Add these variables in your platform's environment settings
# - Mark sensitive values (keys, tokens) as "Secret"
#
# Security Priority Legend:
# 🔴 CRITICAL - Application will fail without these
# 🟠 HIGH - Core features disabled without these
# 🟡 MEDIUM - Optional features affected
# 🟢 LOW - Development/debugging only
# ============================================================================

# ============================================================================
# 🔴 CRITICAL - Application Environment
# ============================================================================

# Application environment mode
# Options: development | staging | production
NODE_ENV=development
VITE_APP_ENV=development

# ============================================================================
# 🔴 CRITICAL - Supabase Configuration
# ============================================================================
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api
#
# ⚠️ SECURITY: Rotate these keys immediately if exposed in git history
# ⚠️ NEVER use production credentials in development/testing

# Primary Supabase Project URL
# Example: https://your-project-id.supabase.co
VITE_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous/Public Key (safe for client-side)
# This key has limited permissions defined by Row Level Security
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# Supabase Project ID
VITE_SUPABASE_PROJECT_ID=your-project-id

# Supabase Service Role Key (CRITICAL - Server-side only)
# ⚠️ NEVER expose this in client code or commit to git
# ⚠️ This key bypasses Row Level Security - use with extreme caution
# Mark as "Secret" in deployment platform
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here

# Portfolio Supabase (if using separate database for portfolios)
VITE_PORTFOLIO_SUPABASE_URL=https://your-portfolio-project-id.supabase.co
VITE_PORTFOLIO_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-portfolio-anon-key-here

# ============================================================================
# 🔴 CRITICAL - Application URLs
# ============================================================================

# Public URL where your application is deployed
# Development: http://localhost:8080
# Staging: https://staging.your-domain.com
# Production: https://app.your-domain.com or https://your-project.lovable.app
NEXT_PUBLIC_APP_URL=http://localhost:8080
VITE_PUBLIC_URL=http://localhost:8080

# API Base URL (if using separate API server)
API_URL=http://localhost:8080/api
VITE_API_URL=http://localhost:8080/api

# ============================================================================
# 🟠 HIGH - Monitoring & Error Tracking
# ============================================================================

# Sentry Configuration for Error Tracking
# Get from: https://sentry.io/settings/projects/YOUR_PROJECT/keys/
# Note: DSN can be public, auth token must be secret
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-organization
SENTRY_PROJECT=indigo-platform

# Sentry Environment & Release Tracking
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=1.0.0

# ============================================================================
# 🟠 HIGH - Analytics & Product Tracking
# ============================================================================

# PostHog Configuration for Product Analytics
# Get from: https://posthog.com/project/settings
VITE_POSTHOG_KEY=phc_your_posthog_project_key_here
VITE_POSTHOG_HOST=https://app.posthog.com
POSTHOG_API_KEY=your-posthog-personal-api-key

# PostHog Feature Flags
POSTHOG_FEATURE_FLAGS_ENABLED=true

# ============================================================================
# 🟡 MEDIUM - Email Services
# ============================================================================

# MailerLite API Configuration
# Get from: https://app.mailerlite.com/integrations/api
# Used for transactional emails and investor communications
MAILERLITE_API_KEY=your-mailerlite-api-key
MAILERLITE_API_TOKEN=your-mailerlite-api-token
VITE_MAILERLITE_ENABLED=false

# Alternative: SMTP Configuration
# Use if you prefer SMTP over MailerLite
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@your-domain.com
SMTP_FROM_NAME=Indigo Yield Platform

# ============================================================================
# 🟡 MEDIUM - Airtable Integration
# ============================================================================
# Used for investor onboarding workflow and data synchronization
# Get API key from: https://airtable.com/create/tokens
# Can be disabled via AIRTABLE_SYNC_ENABLED flag

# Airtable Personal Access Token
VITE_AIRTABLE_API_KEY=patXXXXXXXXXXXXXX
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX

# Airtable Base Configuration
VITE_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Airtable Table Names
VITE_AIRTABLE_TABLE_NAME=Investor Onboarding
AIRTABLE_TABLE_NAME=Investor Onboarding

# Airtable Sync Configuration
AIRTABLE_SYNC_ENABLED=false
AIRTABLE_SYNC_INTERVAL_MS=300000
AIRTABLE_WEBHOOK_SECRET=your_webhook_secret

# ============================================================================
# 🟡 MEDIUM - Feature Flags & Environment Overrides
# ============================================================================

# Preview/Demo Mode (allows testing with mock data)
VITE_PREVIEW_ADMIN=false
VITE_DEMO_MODE=false

# Enable/Disable specific features (overrides src/config/features.ts)
VITE_FEATURE_CUSTOM_REPORTS=false
VITE_FEATURE_PDF_GENERATION=false
VITE_FEATURE_TWO_FACTOR_AUTH=false
VITE_FEATURE_DARK_MODE=false
VITE_FEATURE_PUSH_NOTIFICATIONS=false

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_ENABLED=true

# ============================================================================
# 🟢 LOW - Development & CI/CD
# ============================================================================

# Development Server Configuration
VITE_PORT=8080
VITE_HOST=localhost

# Build Configuration
VITE_BUILD_SOURCEMAP=true
VITE_BUILD_MINIFY=true

# Database URLs (for local development and migrations)
SUPABASE_DEV_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres
SUPABASE_STAGING_DB_URL=postgresql://user:password@host:port/database
SUPABASE_PROD_DB_URL=postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# CI/CD Tokens (for automated deployments)
GITHUB_TOKEN=ghp_your_github_personal_access_token

# Supabase CLI Configuration (for local development)
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
SUPABASE_PROJECT_REF=your-project-ref

# ============================================================================
# 🟢 LOW - Testing & QA
# ============================================================================

# Test Environment Configuration
TEST_ENV=test
VITEST_COVERAGE=true
PLAYWRIGHT_BASE_URL=http://localhost:8080

# Test Database URLs
TEST_SUPABASE_URL=https://test-project.supabase.co
TEST_SUPABASE_ANON_KEY=your-test-anon-key

# Mock Service Configuration
MOCK_API_ENABLED=false
MOCK_EMAILS_ENABLED=false

# ============================================================================
# 🟢 LOW - Logging & Debugging
# ============================================================================

# Logging Configuration
LOG_LEVEL=info
VITE_LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_DEBUG_LOGS=false

# Performance Monitoring
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_SAMPLE_RATE=0.1

# ============================================================================
# 🟢 LOW - Phase 2/3 Features (Not Yet Implemented)
# ============================================================================

# Web Push Notifications (Phase 2)
WEB_PUSH_VAPID_PUBLIC_KEY=your_vapid_public_key
WEB_PUSH_VAPID_PRIVATE_KEY=your_vapid_private_key
WEB_PUSH_SUBJECT=mailto:admin@your-domain.com

# Asset Storage Buckets (Phase 2)
REPORT_BRANDING_ASSET_BUCKET=branding-assets
PDF_FONT_ASSETS_BUCKET=pdf-fonts
DOCUMENT_STORAGE_BUCKET=investor-documents

# Portfolio Share Links (Phase 2)
SHARE_LINK_BASE_URL=https://your-domain.com/share
SHARE_LINK_EXPIRY_DAYS=7

# Two-Factor Authentication (Phase 2)
TOTP_ISSUER=Indigo Yield Platform
TOTP_DIGITS=6
TOTP_PERIOD=30

# Advanced Analytics (Phase 3)
ANALYTICS_RETENTION_DAYS=90
ANALYTICS_EXPORT_ENABLED=false

# API Access (Phase 3)
API_RATE_LIMIT_PER_HOUR=1000
API_KEY_PREFIX=iyp_
API_WEBHOOK_SECRET=your-webhook-signing-secret

# ============================================================================
# Environment-Specific Validation
# ============================================================================
#
# Development Requirements:
# - VITE_SUPABASE_URL
# - VITE_SUPABASE_ANON_KEY
# - NODE_ENV=development
#
# Staging Requirements:
# - All Development requirements
# - VITE_SENTRY_DSN (recommended)
# - VITE_POSTHOG_KEY (recommended)
#
# Production Requirements:
# - All Critical variables (🔴)
# - All High priority variables (🟠)
# - SUPABASE_SERVICE_ROLE_KEY (server-side only)
# - Proper SSL/TLS configuration
# - Rate limiting enabled
# - Error tracking enabled
#
# ============================================================================
# Deployment Checklist
# ============================================================================
#
# Before deploying to ANY environment:
# ✅ 1. Copy this file to .env.[environment]
# ✅ 2. Fill in all CRITICAL (🔴) variables
# ✅ 3. Rotate any keys exposed in git history
# ✅ 4. Verify URLs match the target environment
# ✅ 5. Enable appropriate feature flags
# ✅ 6. Configure error tracking (Sentry)
# ✅ 7. Configure analytics (PostHog)
# ✅ 8. Test database connectivity
# ✅ 9. Verify email delivery (if enabled)
# ✅ 10. Run smoke tests before going live
#
# Security Best Practices:
# - Never commit .env files to git (except .env.example)
# - Use different credentials for each environment
# - Rotate keys regularly (90 days recommended)
# - Use secret management tools for production
# - Enable audit logging for key access
# - Restrict service role key to server-side only
# - Use environment variable encryption in CI/CD
#
# ============================================================================
