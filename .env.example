# ============================================================================
# Indigo Yield Platform - Environment Variables
# ============================================================================
#
# IMPORTANT: Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it contains sensitive credentials
#
# For Lovable deployment:
# 1. Go to Lovable Dashboard → Project → Settings → Environment Variables
# 2. Add each variable below
# 3. Mark sensitive values (keys, passwords, tokens) as "Secret"
#
# Priority Legend:
# 🔴 CRITICAL - Application won't work without these
# 🟠 HIGH - Core features need these
# 🟡 MEDIUM - Optional features, degraded functionality without them
# 🟢 LOW - Future features, safe to leave empty for MVP
# ============================================================================

# ============================================================================
# 🔴 CRITICAL - Supabase Configuration (REQUIRED)
# ============================================================================
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api

# Supabase project URL
# Example: https://nkfimvovosdehmyyjubn.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous (public) key - safe to expose in client
# ⚠️ ROTATE THIS - exposed in git history
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key - KEEP SECRET, server-side only
# ⚠️ ROTATE THIS - exposed in git history
# Mark as "Secret" in Lovable dashboard
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# 🔴 CRITICAL - Application Configuration
# ============================================================================

# Application environment (development | staging | production)
VITE_APP_ENV=production

# Public URL of your deployed application
# Lovable: https://your-project.lovable.app
# Custom domain: https://app.your-domain.com
NEXT_PUBLIC_APP_URL=https://your-project.lovable.app

# Preview/Demo mode for testing (true | false)
VITE_PREVIEW_ADMIN=false

# ============================================================================
# 🟠 HIGH - Monitoring & Error Tracking (Recommended)
# ============================================================================

# Sentry DSN for error tracking
# Get from: https://sentry.io/settings/projects/YOUR_PROJECT/keys/
# ⚠️ ROTATE THIS - exposed in git history
VITE_SENTRY_DSN=your-sentry-dsn-here
SENTRY_DSN=your-sentry-dsn-here

# Sentry auth token for source maps upload (optional)
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# PostHog API key for analytics
# Get from: https://posthog.com/project/settings
# ⚠️ ROTATE THIS - exposed in git history
VITE_POSTHOG_KEY=phc_your_posthog_key_here
VITE_POSTHOG_HOST=https://app.posthog.com

# PostHog API key for server-side tracking (optional)
POSTHOG_API_KEY=your-posthog-api-key

# ============================================================================
# 🟡 MEDIUM - Email Service (Optional for MVP)
# ============================================================================

# MailerLite API key for email marketing/transactional emails
# Get from: https://app.mailerlite.com/integrations/api
# ⚠️ ROTATE THIS - exposed in git history
# Note: Email features will be degraded without this
MAILERLITE_API_KEY=your-mailerlite-api-key

# Alternative: Custom SMTP configuration
# Use if you prefer SMTP over MailerLite
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_password

# ============================================================================
# 🟡 MEDIUM - Airtable Integration (Optional)
# ============================================================================
# Used for investor onboarding workflow
# Get API key from: https://airtable.com/create/tokens
# Can be disabled via feature flag: AIRTABLE_SYNC = false

# Airtable Personal Access Token
VITE_AIRTABLE_API_KEY=patXXXXXXXXXXXXXX
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX

# Base ID from your Airtable URL (e.g., appRQG95vXyKoRhdH)
VITE_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Table name for onboarding submissions
VITE_AIRTABLE_TABLE_NAME=Investor Onboarding
AIRTABLE_TABLE_NAME=Investor Onboarding

# Webhook secret for Airtable webhooks (optional, real-time sync)
AIRTABLE_WEBHOOK_SECRET=your_webhook_secret

# Sync configuration
AIRTABLE_SYNC_ENABLED=false
AIRTABLE_SYNC_INTERVAL_MS=300000

# ============================================================================
# 🟢 LOW - Development & CI/CD (Optional)
# ============================================================================

# GitHub token for CI/CD deployments (optional)
GITHUB_TOKEN=ghp_your_github_token

# Vercel token for deployments (optional)
VERCEL_TOKEN=your_vercel_token

# Supabase database connection strings (for local development)
SUPABASE_DEV_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres
SUPABASE_PROD_DB_URL=postgresql://user:password@host:port/database

# ============================================================================
# 🟢 LOW - Phase 2/3 Features (Not Yet Implemented)
# ============================================================================

# Web Push Notifications (Phase 2 - PUSH_NOTIFICATIONS feature flag)
WEB_PUSH_VAPID_PUBLIC_KEY=your_vapid_public_key
WEB_PUSH_VAPID_PRIVATE_KEY=your_vapid_private_key

# Asset Storage Buckets (Phase 2 - Custom report branding)
REPORT_BRANDING_ASSET_BUCKET=branding-assets
PDF_FONT_ASSETS_BUCKET=pdf-fonts

# Portfolio Share Links (Phase 2 - Share portfolio via link)
SHARE_LINK_BASE_URL=https://your-domain.com/share

# ============================================================================
# Environment Variable Summary
# ============================================================================
#
# Total Variables: 30+
# CRITICAL (🔴): 5
#   - VITE_SUPABASE_URL
#   - VITE_SUPABASE_ANON_KEY
#   - SUPABASE_SERVICE_ROLE_KEY
#   - VITE_APP_ENV
#   - NEXT_PUBLIC_APP_URL
#
# HIGH (🟠): 5
#   - VITE_SENTRY_DSN
#   - SENTRY_DSN
#   - VITE_POSTHOG_KEY
#   - VITE_POSTHOG_HOST
#   - POSTHOG_API_KEY
#
# MEDIUM (🟡): 10
#   - MAILERLITE_API_KEY
#   - SMTP_* (4 variables)
#   - AIRTABLE_* (5 variables)
#
# LOW (🟢): 10+
#   - Development tools, Phase 2/3 features
#
# ============================================================================
# Deployment Checklist
# ============================================================================
#
# Before deploying to Lovable:
# ✅ 1. Rotate ALL keys marked with ⚠️ (exposed in git history)
# ✅ 2. Generate new Supabase anon and service role keys
# ✅ 3. Create new Sentry project and get new DSN
# ✅ 4. Create new PostHog project and get new API key
# ✅ 5. Generate new MailerLite API key
# ✅ 6. Generate new SMTP password (if using SMTP)
# ✅ 7. Add all CRITICAL and HIGH variables to Lovable
# ✅ 8. Mark all *_KEY, *_TOKEN, *_PASSWORD as "Secret" in Lovable
# ✅ 9. Test application with new credentials in staging
# ✅ 10. Deploy to production
#
# ============================================================================
