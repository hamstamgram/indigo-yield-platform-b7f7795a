# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Preview/Demo Mode
VITE_PREVIEW_ADMIN=false
VITE_APP_ENV=development

# GitHub Integration
GITHUB_TOKEN=your_github_token_here

# Supabase Database URLs
SUPABASE_DEV_DB_URL=postgresql://user:password@host:port/database
SUPABASE_PROD_DB_URL=postgresql://user:password@host:port/database

# Vercel Deployment
VERCEL_TOKEN=your_vercel_token_here

# Sentry Error Tracking
VITE_SENTRY_DSN=your_sentry_dsn_here
SENTRY_DSN=your_sentry_dsn_here
SENTRY_TOKEN=your_sentry_token

# MailerLite Email Marketing
MAILERLITE_API_KEY=your_mailerlite_api_key

# Optional: Email (if using custom SMTP implementation)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_password

# Web Push Notifications (Phase 3.6)
WEB_PUSH_VAPID_PUBLIC_KEY=your_vapid_public_key
WEB_PUSH_VAPID_PRIVATE_KEY=your_vapid_private_key

# Asset Storage Buckets
REPORT_BRANDING_ASSET_BUCKET=branding-assets
PDF_FONT_ASSETS_BUCKET=pdf-fonts

# Portfolio Share Links
SHARE_LINK_BASE_URL=https://your-domain.com/share

# PostHog Analytics
VITE_POSTHOG_KEY=phc_your_posthog_key_here
VITE_POSTHOG_HOST=https://app.posthog.com
POSTHOG_API_KEY=your_posthog_api_key_here
