{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2020",
    "useDefineForClassFields": true,
    "types": ["node", "vite/client"]
  },
  "exclude": [
    "node_modules",
    "supabase/functions",
    "supabase/functions_archive",
    "tests",
    "test-reports",
    "scripts",
    "vite.config.ts",
    "archive"
  ],
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
