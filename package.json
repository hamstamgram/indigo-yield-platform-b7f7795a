{
  "name": "indigo-yield-platform",
  "private": true,
  "version": "1.0.2",
  "description": "Unified package.json for Indigo Yield Platform",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:staging": "tsc && vite build --mode staging",
    "start": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,md,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:auth": "playwright test tests/auth-integration.spec.ts",
    "test:auth:headed": "playwright test tests/auth-integration.spec.ts --headed",
    "test:supabase": "playwright test tests/supabase-integration.spec.ts",
    "test:cross-platform": "playwright test tests/cross-platform-verification.spec.ts",
    "test:unit": "vitest run tests/unit --coverage",
    "test:integration": "vitest run tests/integration --coverage",
    "test:accessibility": "playwright test tests/accessibility",
    "test:ci": "vitest run --coverage --pool=threads --poolOptions.threads.maxThreads=2",
    "test:all": "./scripts/run-all-tests.sh",
    "test:generate": "node scripts/generate-tests.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "audit:playwright": "playwright test --reporter=line",
    "audit:lhci": "lhci autorun",
    "audit:headers": "node scripts/check-headers.mjs",
    "audit:rls": "node scripts/rls-tests.mjs",
    "audit:report": "node scripts/build-report.mjs",
    "contracts:verify": "ts-node scripts/verify-enum-contracts.ts",
    "contracts:verify-schema": "npx ts-node --esm scripts/contracts/verify-schema-against-frontend.ts",
    "contracts:scan": "npx ts-node --esm scripts/contracts/scan-frontend-queries.ts",
    "contracts:generate": "ts-node scripts/generate-contracts.ts",
    "schema:snapshot": "npx ts-node --esm scripts/contracts/generate-schema-snapshot.ts",
    "schema:truth": "bash scripts/schema-truth-pack.sh",
    "seed:golden": "npx ts-node --esm scripts/seed/seed-golden-path.ts",
    "flows:run": "npx ts-node --esm scripts/flows/run-flow-pack.ts",
    "test:contracts": "npm run schema:snapshot && npm run contracts:verify-schema && npm run contracts:scan",
    "test:golden": "playwright test tests/e2e/golden-path.spec.ts",
    "test:full": "npm run test:contracts && npm run seed:golden && npm run flows:run",
    "sql:hygiene": "ts-node scripts/sql-hygiene-check.ts",
    "gateway:check": "ts-node scripts/check-gateway-usage.ts",
    "integrity:check": "npm run contracts:verify && npm run sql:hygiene && npm run gateway:check",
    "phase2:verify": "npx ts-node --esm scripts/verify-phase2-migration.ts",
    "db:smoke-test": "bash scripts/db-smoke-test.sh",
    "db:smoke-test:ci": "bash scripts/db-smoke-test.sh --ci",
    "audit:full": "bash scripts/run-full-audit.sh",
    "drift:verify": "ts-node scripts/verify-contracts.ts",
    "check:services": "node scripts/service-checks.mjs",
    "fix:rls": "node scripts/apply-rls-fix.mjs",
    "prepare": "husky",
    "perf:test": "node scripts/performance-test.mjs",
    "perf:analyze": "node scripts/bundle-analyzer.mjs",
    "perf:images": "node scripts/optimize-images.mjs",
    "perf:db": "psql $DATABASE_URL -f scripts/optimize-database.sql",
    "perf:all": "npm run perf:images && npm run build && npm run perf:analyze && npm run perf:test"
  },
  "dependencies": {
    "@fontsource/montserrat": "^5.2.8",
    "@heroicons/react": "^2.0.18",
    "@hookform/resolvers": "^3.9.0",
    "@mailerlite/mailerlite-nodejs": "^1.4.1",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-aspect-ratio": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-context-menu": "^2.2.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-hover-card": "^1.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-menubar": "^1.1.1",
    "@radix-ui/react-navigation-menu": "^1.2.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-toggle": "^1.1.0",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@supabase/supabase-js": "^2.39.7",
    "@tanstack/react-query": "^5.17.19",
    "@tanstack/react-table": "^8.11.7",
    "@types/dompurify": "^3.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "chart.js": "^4.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "cmdk": "^1.0.0",
    "date-fns": "^3.3.1",
    "decimal.js": "^10.6.0",
    "dompurify": "^3.3.1",
    "dotenv": "^17.2.2",
    "embla-carousel-react": "^8.3.0",
    "exceljs": "^4.4.0",
    "express-rate-limit": "^8.0.1",
    "framer-motion": "^11.0.3",
    "immer": "^10.1.3",
    "input-otp": "^1.2.4",
    "joi": "^18.0.1",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.462.0",
    "next-themes": "^0.3.0",
    "node-fetch": "^3.3.2",
    "otpauth": "^9.4.1",
    "pdfjs-dist": "^5.4.394",
    "pg": "^8.16.3",
    "posthog-js": "^1.261.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.0.3",
    "react-hook-form": "^7.49.3",
    "react-pdf": "^10.2.0",
    "react-resizable-panels": "^2.1.3",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.4",
    "sonner": "^1.5.0",
    "speakeasy": "^2.0.0",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^0.9.3",
    "vitest": "^4.0.13",
    "zod": "^3.25.76",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@brave/brave-search-mcp-server": "^1.3.7",
    "@brightdata/mcp": "^2.5.0",
    "@eslint/js": "^9.9.0",
    "@felores/airtable-mcp-server": "^0.3.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.55.0",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-docs": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-onboarding": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.52",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "@upstash/context7-mcp": "^1.0.17",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "autoprefixer": "^10.4.17",
    "babel-jest": "^30.2.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.2.6",
    "lovable-tagger": "^1.1.7",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.33",
    "prettier": "^3.2.4",
    "puppeteer": "^24.19.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "sharp": "^0.34.3",
    "storybook": "^8.6.14",
    "tailwindcss": "^3.4.1",
    "terser": "^5.44.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.1",
    "xlsx": "^0.18.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{js,jsx,ts,tsx,md,json}": [
      "prettier --write"
    ]
  }
}
