# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Production Supabase (if different)
SUPABASE_URL_PROD=https://your-prod-project-ref.supabase.co
SUPABASE_ANON_KEY_PROD=your-prod-anon-key-here

# Admin Service Key (store securely, never commit)
# SUPABASE_SERVICE_KEY=your-service-role-key-here

# Optional: API Configuration
API_BASE_URL=http://localhost:3000
API_TIMEOUT=30

# Optional: Feature Flags
ENABLE_BIOMETRIC_AUTH=true
ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_ANALYTICS=false
ENABLE_CRASH_REPORTING=false

# Optional: Sentry for crash reporting (production)
# SENTRY_DSN=your-sentry-dsn-here
