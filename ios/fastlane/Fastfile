# Fastfile
# Automated deployment configuration for IndigoInvestor

default_platform(:ios)

platform :ios do
  
  # Lane for running tests
  desc "Run all tests"
  lane :test do
    scan(
      workspace: "IndigoInvestor.xcworkspace",
      scheme: "IndigoInvestor",
      clean: true,
      devices: ["iPhone 14 Pro"],
      code_coverage: true
    )
  end
  
  # Lane for TestFlight deployment
  desc "Deploy to TestFlight"
  lane :beta do
    # Ensure we're on the main branch
    ensure_git_status_clean
    ensure_git_branch(branch: "main")
    
    # Increment build number
    increment_build_number(xcodeproj: "IndigoInvestor.xcodeproj")
    
    # Get certificates and provisioning profiles
    match(
      type: "appstore",
      app_identifier: "com.indigoyield.investor",
      readonly: false
    )
    
    # Build the app
    gym(
      workspace: "IndigoInvestor.xcworkspace",
      scheme: "IndigoInvestor",
      configuration: "Release",
      clean: true,
      output_directory: "./build",
      output_name: "IndigoInvestor.ipa",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.indigoyield.investor" => "IndigoInvestor Distribution"
        }
      }
    )
    
    # Upload to TestFlight
    pilot(
      app_identifier: "com.indigoyield.investor",
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false,
      changelog: "Bug fixes and performance improvements"
    )
    
    # Create git tag
    add_git_tag(
      grouping: "builds",
      prefix: "v",
      build_number: get_build_number(xcodeproj: "IndigoInvestor.xcodeproj")
    )
    
    # Push to git
    push_to_git_remote
    
    # Send Slack notification
    slack(
      message: "Successfully deployed IndigoInvestor to TestFlight! 🚀",
      success: true,
      default_payloads: [:git_branch, :git_author, :last_git_commit_message]
    )
  end
  
  # Lane for App Store release
  desc "Deploy to App Store"
  lane :release do
    # Ensure we're on the release branch
    ensure_git_status_clean
    ensure_git_branch(branch: "release")
    
    # Get certificates and provisioning profiles
    match(
      type: "appstore",
      app_identifier: "com.indigoyield.investor",
      readonly: true
    )
    
    # Build the app
    gym(
      workspace: "IndigoInvestor.xcworkspace",
      scheme: "IndigoInvestor",
      configuration: "Release",
      clean: true,
      output_directory: "./build",
      output_name: "IndigoInvestor.ipa",
      export_method: "app-store"
    )
    
    # Upload to App Store Connect
    deliver(
      app_identifier: "com.indigoyield.investor",
      submit_for_review: false,
      automatic_release: false,
      force: true,
      metadata_path: "./fastlane/metadata",
      screenshots_path: "./fastlane/screenshots",
      build_number: get_build_number(xcodeproj: "IndigoInvestor.xcodeproj")
    )
    
    # Create release tag
    add_git_tag(
      grouping: "releases",
      prefix: "release-",
      build_number: get_version_number(xcodeproj: "IndigoInvestor.xcodeproj")
    )
    
    # Push to git
    push_to_git_remote
    
    # Send Slack notification
    slack(
      message: "Successfully deployed IndigoInvestor to App Store Connect! 🎉",
      success: true,
      default_payloads: [:git_branch, :git_author]
    )
  end
  
  # Lane for creating screenshots
  desc "Generate App Store screenshots"
  lane :screenshots do
    snapshot(
      workspace: "IndigoInvestor.xcworkspace",
      scheme: "IndigoInvestorUITests",
      output_directory: "./fastlane/screenshots",
      clear_previous_screenshots: true,
      devices: [
        "iPhone 14 Pro Max",
        "iPhone 14 Pro",
        "iPhone 8 Plus",
        "iPad Pro (12.9-inch) (6th generation)"
      ]
    )
    
    frame_screenshots(
      path: "./fastlane/screenshots"
    )
  end
  
  # Lane for code signing setup
  desc "Setup code signing"
  lane :certificates do
    match(
      type: "development",
      app_identifier: "com.indigoyield.investor",
      readonly: false
    )
    
    match(
      type: "appstore",
      app_identifier: "com.indigoyield.investor",
      readonly: false
    )
  end
  
  # Error handling
  error do |lane, exception|
    slack(
      message: "Error in lane #{lane}: #{exception.message}",
      success: false
    )
  end
end
