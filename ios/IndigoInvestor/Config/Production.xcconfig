// Production Environment Configuration
// This file contains production environment settings

// App Configuration
APP_NAME = IndigoInvestor
APP_BUNDLE_ID = com.indigoyield.investor
APP_ICON = AppIcon
APP_VERSION = 1.0.0
APP_BUILD = 1

// Supabase Configuration
SUPABASE_URL = https://prod.supabase.co
SUPABASE_ANON_KEY = $(PROD_SUPABASE_ANON_KEY)
SUPABASE_PROJECT_REF = prod-project-ref

// API Configuration
API_ENVIRONMENT = production
API_BASE_URL = https://api.indigoyield.com
ENABLE_NETWORK_LOGGING = NO
ENABLE_DEBUG_MENU = NO

// Security
CERTIFICATE_PINS = prod.supabase.co:sha256/ccccc,api.indigoyield.com:sha256/ddddd
ENFORCE_CERTIFICATE_PINNING = YES
JAILBREAK_DETECTION_ENABLED = YES

// Analytics & Monitoring
ANALYTICS_ENABLED = YES
CRASH_REPORTING_ENABLED = YES
PERFORMANCE_MONITORING_ENABLED = YES

// Feature Flags
ENABLE_BIOMETRIC_AUTH = YES
ENABLE_2FA = YES
ENABLE_PUSH_NOTIFICATIONS = YES
ENABLE_WIDGETS = YES
ENABLE_OFFLINE_MODE = YES
ENABLE_ADMIN_FEATURES = YES

// Push Notifications
APN_ENVIRONMENT = production
PUSH_TOPIC = com.indigoyield.investor

// Other Settings
ENABLE_PREVIEWS = NO
USE_MOCK_DATA = NO
