// Dev Environment Configuration
// This file contains development environment settings

// App Configuration
APP_NAME = IndigoInvestor Dev
APP_BUNDLE_ID = com.indigoyield.investor.dev
APP_ICON = AppIcon-Dev
APP_VERSION = 1.0.0
APP_BUILD = 1

// Supabase Configuration
SUPABASE_URL = https://dev.supabase.co
SUPABASE_ANON_KEY = $(DEV_SUPABASE_ANON_KEY)
SUPABASE_PROJECT_REF = dev-project-ref

// API Configuration
API_ENVIRONMENT = development
API_BASE_URL = https://api-dev.indigoyield.com
ENABLE_NETWORK_LOGGING = YES
ENABLE_DEBUG_MENU = YES

// Security
CERTIFICATE_PINS = dev.supabase.co:sha256/xxxxx,api-dev.indigoyield.com:sha256/yyyyy
ENFORCE_CERTIFICATE_PINNING = NO
JAILBREAK_DETECTION_ENABLED = NO

// Analytics & Monitoring
ANALYTICS_ENABLED = NO
CRASH_REPORTING_ENABLED = NO
PERFORMANCE_MONITORING_ENABLED = YES

// Feature Flags
ENABLE_BIOMETRIC_AUTH = YES
ENABLE_2FA = YES
ENABLE_PUSH_NOTIFICATIONS = YES
ENABLE_WIDGETS = YES
ENABLE_OFFLINE_MODE = YES
ENABLE_ADMIN_FEATURES = YES

// Push Notifications
APN_ENVIRONMENT = development
PUSH_TOPIC = com.indigoyield.investor.dev

// Other Settings
ENABLE_PREVIEWS = YES
USE_MOCK_DATA = NO
