// Staging Environment Configuration
// This file contains staging environment settings

// App Configuration
APP_NAME = IndigoInvestor Beta
APP_BUNDLE_ID = com.indigoyield.investor.staging
APP_ICON = AppIcon-Staging
APP_VERSION = 1.0.0
APP_BUILD = 1

// Supabase Configuration
SUPABASE_URL = https://staging.supabase.co
SUPABASE_ANON_KEY = $(STAGING_SUPABASE_ANON_KEY)
SUPABASE_PROJECT_REF = staging-project-ref

// API Configuration
API_ENVIRONMENT = staging
API_BASE_URL = https://api-staging.indigoyield.com
ENABLE_NETWORK_LOGGING = YES
ENABLE_DEBUG_MENU = NO

// Security
CERTIFICATE_PINS = staging.supabase.co:sha256/aaaaa,api-staging.indigoyield.com:sha256/bbbbb
ENFORCE_CERTIFICATE_PINNING = YES
JAILBREAK_DETECTION_ENABLED = YES

// Analytics & Monitoring
ANALYTICS_ENABLED = YES
CRASH_REPORTING_ENABLED = YES
PERFORMANCE_MONITORING_ENABLED = YES

// Feature Flags
ENABLE_BIOMETRIC_AUTH = YES
ENABLE_2FA = YES
ENABLE_PUSH_NOTIFICATIONS = YES
ENABLE_WIDGETS = YES
ENABLE_OFFLINE_MODE = YES
ENABLE_ADMIN_FEATURES = YES

// Push Notifications
APN_ENVIRONMENT = development
PUSH_TOPIC = com.indigoyield.investor.staging

// Other Settings
ENABLE_PREVIEWS = NO
USE_MOCK_DATA = NO
