{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-filesystem", "/Users/mama/indigo-yield-platform-v01"],
      "description": "File system operations for the project directory"
    },
    "memory": {
      "command": "node",
      "args": [
        "/Users/mama/Desktop/mcp-servers/mcp-servers-official/src/memory/dist/index.js"
      ],
      "env": {
        "MEMORY_DB_PATH": "/Users/mama/indigo-yield-platform-v01/.mcp/memory.sqlite"
      },
      "description": "Persistent memory storage for context and information"
    },
    "sequentialthinking": {
      "command": "node",
      "args": [
        "/Users/mama/Desktop/mcp-servers/mcp-servers-official/src/sequentialthinking/dist/index.js"
      ],
      "env": {
        "SEQTHINK_MAX_STEPS": "10"
      },
      "description": "Sequential thinking and reasoning capabilities"
    },
    "brightdata": {
      "command": "npx",
      "args": [
        "-y",
        "@brightdata/mcp@2.5.0"
      ],
      "env": {
        "BRIGHTDATA_API_TOKEN": "{{env.BRIGHTDATA_API_TOKEN}}"
      },
      "description": "Web scraping and data collection via Bright Data"
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@1.0.17"
      ],
      "env": {
        "UPSTASH_VECTOR_REST_URL": "{{env.UPSTASH_VECTOR_REST_URL}}",
        "UPSTASH_VECTOR_REST_TOKEN": "{{env.UPSTASH_VECTOR_REST_TOKEN}}"
      },
      "description": "Vector database and context management via Upstash"
    },
    "brave-search": {
      "command": "npx",
      "args": [
        "-y",
        "@brave/brave-search-mcp-server@1.3.7"
      ],
      "env": {
        "BRAVE_API_KEY": "{{env.BRAVE_API_KEY}}"
      },
      "description": "Web search using Brave Search API with AI summaries and rich results"
    },
    "enhanced-postgres-dev": {
      "command": "npx",
      "args": ["enhanced-postgres-mcp-server"],
      "env": {
        "DATABASE_URL": "{{env.SUPABASE_DEV_DB_URL}}"
      },
      "description": "Enhanced PostgreSQL for development (supplement to existing Supabase MCP)"
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp"],
      "env": {
        "BASE_URL": "http://localhost:5173",
        "BROWSER": "chromium",
        "HEADLESS": "false",
        "DEVICES": "[\"Desktop Chrome HiDPI\",\"iPhone 15 Pro\"]",
        "VIEWPORT_WIDTH": "1440",
        "VIEWPORT_HEIGHT": "900",
        "NAV_TIMEOUT_MS": "15000"
      },
      "description": "Browser automation and testing"
    },
    "vercel": {
      "command": "npx",
      "args": ["@vercel/mcp-adapter"],
      "env": {
        "VERCEL_TOKEN": "{{env.VERCEL_TOKEN}}"
      },
      "description": "Vercel deployment and management"
    },
    "sentry": {
      "command": "npx",
      "args": ["@sentry/mcp-server"],
      "env": {
        "SENTRY_AUTH_TOKEN": "{{env.SENTRY_TOKEN}}"
      },
      "description": "Error tracking and monitoring with Sentry"
    },
    "mailerlite": {
      "command": "node",
      "args": ["/Users/mama/indigo-yield-platform-v01/mcp-servers/mailerlite-simple.js"],
      "env": {
        "MAILERLITE_API_TOKEN": "{{env.MAILERLITE_API_TOKEN}}"
      },
      "description": "Email marketing and automation with MailerLite (custom MCP server)"
    }
  },
  "environment_variables": {
    "required": [
      "GITHUB_TOKEN",
      "SUPABASE_DEV_DB_URL",
      "SUPABASE_PROD_DB_URL",
      "VERCEL_TOKEN",
      "SENTRY_TOKEN",
      "MAILERLITE_API_TOKEN"
    ],
    "optional": [
      "SMTP_HOST",
      "SMTP_PORT",
      "SMTP_USER",
      "SMTP_PASS",
      "POSTHOG_KEY"
    ]
  },
  "notes": {
    "smtp": "For transactional emails, use nodemailer or similar libraries directly. For marketing emails, use MailerLite MCP.",
    "posthog": "No dedicated MCP server found. Use posthog-node or posthog-js directly.",
    "mailerlite": "Use for email marketing campaigns, subscriber management, and automation. Requires MAILERLITE_API_TOKEN from your MailerLite account.",
    "security": "Always use dev environment for testing. Prod access requires extra caution.",
    "rls": "Remember to test RLS policies on investor tables for each PR as per project rules."
  }
}
