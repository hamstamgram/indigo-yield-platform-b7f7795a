{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-filesystem", "/Users/mama/indigo-yield-platform-v01"]
    },
    "playwright-local": {
      "command": "npx",
      "args": ["@playwright/mcp"],
      "env": {
        "BASE_URL": "http://localhost:5173",
        "BROWSER": "chromium",
        "HEADLESS": "false",
        "DEVICES": "[\"Desktop Chrome HiDPI\",\"iPhone 15 Pro\"]",
        "VIEWPORT_WIDTH": "1440",
        "VIEWPORT_HEIGHT": "900",
        "NAV_TIMEOUT_MS": "15000"
      }
    },
    "vercel": {
      "command": "npx",
      "args": ["@vercel/mcp-adapter"],
      "env": {
        "VERCEL_TOKEN": "{{env.VERCEL_TOKEN}}"
      }
    },
    "sentry": {
      "command": "npx",
      "args": ["@sentry/mcp-server"],
      "env": {
        "SENTRY_AUTH_TOKEN": "{{env.SENTRY_TOKEN}}"
      }
    },
    "enhanced-postgres-dev": {
      "command": "npx",
      "args": ["enhanced-postgres-mcp-server"],
      "env": {
        "DATABASE_URL": "{{env.SUPABASE_DEV_DB_URL}}"
      }
    },
    "airtable": {
      "command": "bash",
      "args": [
        "-lc",
        "source /Users/mama/indigo-yield-platform-v01/.env.mcp && npx -y @felores/airtable-mcp-server"
      ],
      "disabled": false
    }
  }
}
